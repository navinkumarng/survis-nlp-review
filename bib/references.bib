@inproceedings{Ahn2022Do,
  abstract = {Ahn et al. propose SayCan, a framework that grounds large language model outputs in the physical capabilities of a robot. The system combines language model reasoning with affordance scoring to ensure that suggested actions are feasible in the current environment. Evaluated across real-world kitchen manipulation tasks, the framework demonstrates improved long-horizon task completion through grounded language planning.},
  author = {Ahn, Michael and Brohan, Anthony and Brown, Noah A. and Chebotar, Yevgen and Finn, Chelsea and Gopalakrishnan, Keerthana and Hausman, Karol and Ichter, Brian and Irpan, Alex and Jang, Eric B. and Joshi, Nikhil J.},
  booktitle = {Proceedings of the Conference on Robot Learning},
  doi = {10.48550/arXiv.2204.01691},
  keywords = {type:method, robotics, grounding, affordance, embodied_ai, task_planning},
  series = {CoRL},
  title = {Do As {I} Can, Not As {I} Say: Grounding Language in Robotic Affordances},
  url = {https://arxiv.org/abs/2204.01691},
  year = {2022}
}

